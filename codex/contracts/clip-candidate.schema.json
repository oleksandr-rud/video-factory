{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClipCandidate",
  "type": "object",
  "required": ["candidate_id", "scene_id", "route", "status", "scores"],
  "properties": {
    "candidate_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "scene_index": { "type": "integer", "minimum": 0 },
    "source_scenario_path": { "type": "string" },
    "source_scenario_hash": { "type": "string" },
    "source_scene_visual_pack_path": { "type": "string" },
    "scene_visual_pack_id": { "type": "string" },
    "scene_pack_id": { "type": "string" },
    "scenario_scene_fingerprint": { "type": "string" },
    "scene_pack_fingerprint": { "type": "string" },
    "sync_report_path": { "type": "string" },
    "project_id": { "type": "string" },
    "project_path": { "type": "string" },
    "channel_profile_id": { "type": "string" },
    "channel_slug": { "type": "string" },
    "channel_profile_path": { "type": "string" },
    "media_asset_manifest_path": { "type": "string" },
    "media_asset_id": { "type": "string" },
    "route": {
      "type": "string",
      "enum": [
        "remotion_generated",
        "ai_video_generation",
        "stock_clip",
        "user_supplied_media",
        "approved_web_image",
        "source_card_recreation"
      ]
    },
    "provider": { "type": "string" },
    "source_url": { "type": "string" },
    "preview_url": { "type": "string" },
    "local_path": { "type": "string" },
    "remotion_static_file_path": { "type": "string" },
    "remotion_clip_package_path": { "type": "string" },
    "template_id": { "type": "string" },
    "template_ids": { "type": "array", "items": { "type": "string" } },
    "template_contract_path": { "type": "string" },
    "template_contract_paths": { "type": "array", "items": { "type": "string" } },
    "ai_video_generation_package_path": { "type": "string" },
    "generation_id": { "type": "string" },
    "prompt_or_query": { "type": "string" },
    "license_summary": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": { "type": "string" },
          "source_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "description": { "type": "string" },
          "timestamp_seconds": { "type": "number" }
        }
      }
    },
    "cost_estimate": { "type": "string" },
    "technical": {
      "type": "object",
      "properties": {
        "duration_seconds": { "type": "number" },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "fps": { "type": "number" },
        "has_audio": { "type": "boolean" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["semantic_fit", "continuity_fit", "technical_fit", "rights_fit", "editability", "total"],
      "properties": {
        "semantic_fit": { "type": "number" },
        "continuity_fit": { "type": "number" },
        "technical_fit": { "type": "number" },
        "rights_fit": { "type": "number" },
        "editability": { "type": "number" },
        "total": { "type": "number" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "needs_approval", "approved", "rejected", "downloaded", "generated"]
    },
    "rejection_reason": { "type": "string" }
  }
}
