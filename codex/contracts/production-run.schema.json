{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProductionRun",
  "type": "object",
  "required": ["run_id", "request_id", "status", "objective", "artifacts", "qa"],
  "properties": {
    "run_id": { "type": "string" },
    "request_id": { "type": "string" },
    "project_id": { "type": "string" },
    "project_slug": { "type": "string" },
    "project_path": { "type": "string" },
    "objective": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "needs_approval", "blocked", "complete", "revising", "failed"]
    },
    "current_phase": { "type": "string" },
    "artifact_root": { "type": "string" },
    "channel_profile_id": { "type": "string" },
    "channel_slug": { "type": "string" },
    "channel_profile_path": { "type": "string" },
    "producer_criteria_path": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "path", "status"],
        "properties": {
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "owner_agent": { "type": "string" },
          "contract": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "complete", "needs_approval", "blocked", "stale", "superseded"]
          },
          "version": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["handoff_id", "to_agent", "status"],
        "properties": {
          "handoff_id": { "type": "string" },
          "to_agent": { "type": "string" },
          "phase": { "type": "string" },
          "output_contract": { "type": "string" },
          "artifact_paths": { "type": "array", "items": { "type": "string" } },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "complete", "needs_approval", "blocked", "revising"]
          },
          "summary": { "type": "string" }
        }
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["approval_id", "status", "reason"],
        "properties": {
          "approval_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "approved", "rejected", "not_required"] },
          "reason": { "type": "string" },
          "cost_or_credit_estimate": { "type": "string" },
          "related_artifact": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "change_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["change_id", "request", "status", "impact"],
        "properties": {
          "change_id": { "type": "string" },
          "request": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "in_progress", "complete", "blocked", "rejected"] },
          "impact": {
            "type": "string",
            "enum": ["channel_profile", "channel", "scenario", "voiceover", "visual", "ai_generation", "remotion_clip", "timeline", "timeline_sync", "critique", "delivery_metadata", "unknown"]
          },
          "affected_artifacts": { "type": "array", "items": { "type": "string" } },
          "actions": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "review_loops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["loop_id", "status", "iteration", "producer_criteria_path"],
        "properties": {
          "loop_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "pass", "fail", "needs_approval", "blocked", "stopped"]
          },
          "iteration": { "type": "integer" },
          "max_iterations": { "type": "integer" },
          "render_package_path": { "type": "string" },
          "critique_report_path": { "type": "string" },
          "producer_criteria_path": { "type": "string" },
          "failed_gates": { "type": "array", "items": { "type": "string" } },
          "invalidated_artifacts": { "type": "array", "items": { "type": "string" } },
          "preserved_artifacts": { "type": "array", "items": { "type": "string" } },
          "rerun_scope": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["channel_profile", "channel", "scenario", "voiceover", "visual", "ai_generation", "remotion_clip", "timeline", "timeline_sync", "render", "critique", "delivery_metadata"]
            }
          },
          "routed_actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["owner_agent", "action"],
              "properties": {
                "owner_agent": { "type": "string" },
                "action": { "type": "string" },
                "related_finding": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["planned", "in_progress", "complete", "needs_approval", "blocked"]
                }
              }
            }
          },
          "next_action": {
            "type": "string",
            "enum": ["run_critic", "dispatch_revisions", "rerender", "approve_rc", "ask_user", "stop_blocked"]
          },
          "stop_reason": { "type": "string" }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": { "type": "string", "enum": ["blocker", "major", "minor", "note"] },
          "description": { "type": "string" },
          "owner_agent": { "type": "string" },
          "related_artifact": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "qa": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "partial", "not_run"] },
        "summary": { "type": "string" },
        "residual_risks": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
