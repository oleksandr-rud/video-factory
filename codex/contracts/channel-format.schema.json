{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChannelFormat",
  "type": "object",
  "required": ["channel_format_id", "version", "status", "channel_promise", "content_pillars", "narrative_system", "visual_system", "anti_redundancy"],
  "properties": {
    "channel_format_id": { "type": "string" },
    "channel_id": { "type": "string" },
    "channel_profile_id": { "type": "string" },
    "channel_slug": { "type": "string" },
    "channel_root_path": { "type": "string" },
    "channel_profile_path": { "type": "string" },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "needs_review", "deprecated"]
    },
    "source_analysis_ids": { "type": "array", "items": { "type": "string" } },
    "target_content_mismatch_policy": {
      "type": "string",
      "enum": ["none", "visual_format_only", "needs_target_substitution", "blocked", "unknown"]
    },
    "audience": { "type": "string" },
    "platforms": { "type": "array", "items": { "type": "string" } },
    "channel_promise": { "type": "string" },
    "content_pillars": { "type": "array", "items": { "type": "string" } },
    "video_themes": { "type": "array", "items": { "type": "string" } },
    "content_mix": {
      "type": "object",
      "properties": {
        "hero": { "type": "array", "items": { "type": "string" } },
        "hub": { "type": "array", "items": { "type": "string" } },
        "hygiene": { "type": "array", "items": { "type": "string" } }
      }
    },
    "narrative_system": {
      "type": "object",
      "properties": {
        "hook_patterns": { "type": "array", "items": { "type": "string" } },
        "episode_structure": { "type": "array", "items": { "type": "string" } },
        "pacing_rules": { "type": "array", "items": { "type": "string" } },
        "voice_and_tone": { "type": "string" },
        "cta_rules": { "type": "array", "items": { "type": "string" } }
      }
    },
    "visual_system": {
      "type": "object",
      "properties": {
        "colors": { "type": "array", "items": { "type": "string" } },
        "typography": { "type": "array", "items": { "type": "string" } },
        "caption_rules": { "type": "array", "items": { "type": "string" } },
        "layout_rules": { "type": "array", "items": { "type": "string" } },
        "motion_rules": { "type": "array", "items": { "type": "string" } },
        "thumbnail_rules": { "type": "array", "items": { "type": "string" } },
        "source_card_rules": { "type": "array", "items": { "type": "string" } },
        "target_content_substitution_rules": { "type": "array", "items": { "type": "string" } },
        "reusable_assets": { "type": "array", "items": { "type": "string" } },
        "reusable_template_ids": { "type": "array", "items": { "type": "string" } },
        "remotion_template_contract_paths": { "type": "array", "items": { "type": "string" } },
        "vfx_rules": {
          "type": "object",
          "properties": {
            "rule_set_id": { "type": "string" },
            "extends_rule_refs": { "type": "array", "items": { "type": "string" } },
            "allowed_effects": { "type": "array", "items": { "type": "string" } },
            "preferred_effects": { "type": "array", "items": { "type": "string" } },
            "avoid_effects": { "type": "array", "items": { "type": "string" } },
            "quality_rules": { "type": "array", "items": { "type": "string" } },
            "performance_rules": { "type": "array", "items": { "type": "string" } },
            "determinism_rules": { "type": "array", "items": { "type": "string" } },
            "alpha_rules": { "type": "array", "items": { "type": "string" } },
            "media_decode_rules": { "type": "array", "items": { "type": "string" } },
            "transition_rules": { "type": "array", "items": { "type": "string" } },
            "safe_area_rules": { "type": "array", "items": { "type": "string" } },
            "fallback_requirements": { "type": "array", "items": { "type": "string" } },
            "template_policy": { "type": "string" },
            "complex_vfx_policy": { "type": "string" },
            "max_complexity": {
              "type": "string",
              "enum": ["simple_css_svg", "dom_heavy", "canvas", "webgl", "three", "skia", "media_heavy", "hybrid", "unbounded", "unknown"]
            },
            "requires_vfx_profile": { "type": "boolean" },
            "hardening_required_for": { "type": "array", "items": { "type": "string" } },
            "benchmark_required_for": { "type": "array", "items": { "type": "string" } },
            "rule_overrides": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["rule_id", "override_type", "rule"],
                "properties": {
                  "rule_id": { "type": "string" },
                  "base_rule_ref": { "type": "string" },
                  "override_type": {
                    "type": "string",
                    "enum": ["add", "tighten", "relax", "replace", "document_exception"]
                  },
                  "rule": { "type": "string" },
                  "reason": { "type": "string" },
                  "evidence_refs": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "audio_system": {
      "type": "object",
      "properties": {
        "voice_profile_id": { "type": "string" },
        "voice_direction": { "type": "string" },
        "voice_traits": { "type": "array", "items": { "type": "string" } },
        "must_avoid_voice_traits": { "type": "array", "items": { "type": "string" } },
        "pace_wpm_range": { "type": "string" },
        "accent_policy": { "type": "string" },
        "preferred_voice_provider": { "type": "string" },
        "provider_voice_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "voice_id": { "type": "string" },
              "voice_name": { "type": "string" },
              "selection_policy": {
                "type": "string",
                "enum": ["exact_required", "preferred", "fallback", "blocked"]
              },
              "model_id": { "type": "string" },
              "model_profile": { "type": "string" },
              "target_language": { "type": "string" },
              "target_accent": { "type": "string" },
              "language_code": { "type": "string" },
              "usage": { "type": "string" },
              "rights_state": {
                "type": "string",
                "enum": ["approved", "needs_approval", "blocked", "unknown"]
              },
              "rights_notes": { "type": "array", "items": { "type": "string" } },
              "last_inventory_check": { "type": "string" },
              "continuity_notes": { "type": "string" }
            }
          }
        },
        "music_rules": { "type": "array", "items": { "type": "string" } },
        "sfx_rules": { "type": "array", "items": { "type": "string" } },
        "mix_notes": { "type": "string" }
      }
    },
    "technical_defaults": {
      "type": "object",
      "properties": {
        "aspect_ratios": { "type": "array", "items": { "type": "string" } },
        "resolution": { "type": "string" },
        "fps": { "type": "number" },
        "duration_range_seconds": { "type": "string" },
        "export_notes": { "type": "string" }
      }
    },
    "anti_redundancy": {
      "type": "object",
      "properties": {
        "avoid_patterns": { "type": "array", "items": { "type": "string" } },
        "required_novelty": { "type": "array", "items": { "type": "string" } },
        "flex_zones": { "type": "array", "items": { "type": "string" } },
        "review_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] }
        }
      }
    },
    "channel_asset_paths": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
