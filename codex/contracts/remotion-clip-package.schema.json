{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RemotionClipPackage",
  "type": "object",
  "required": ["clip_id", "scene_id", "scene_index", "source_scenario_path", "source_scene_visual_pack_path", "scene_pack_id", "scenario_scene_fingerprint", "props_sync", "composition_id", "status", "duration_seconds", "fps", "width", "height", "component_paths", "render_commands", "qa"],
  "properties": {
    "clip_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "scene_index": { "type": "integer", "minimum": 0 },
    "source_scenario_path": { "type": "string" },
    "source_scenario_hash": { "type": "string" },
    "source_scene_visual_pack_path": { "type": "string" },
    "scene_visual_pack_id": { "type": "string" },
    "scene_pack_id": { "type": "string" },
    "scene_pack_fingerprint": { "type": "string" },
    "scenario_scene_fingerprint": { "type": "string" },
    "sync_report_path": { "type": "string" },
    "project_id": { "type": "string" },
    "project_path": { "type": "string" },
    "channel_profile_id": { "type": "string" },
    "channel_slug": { "type": "string" },
    "channel_profile_path": { "type": "string" },
    "channel_format_id": { "type": "string" },
    "channel_format_path": { "type": "string" },
    "media_asset_manifest_path": { "type": "string" },
    "remotion_project_contract_path": { "type": "string" },
    "remotion_app_root_path": { "type": "string" },
    "candidate_id": { "type": "string" },
    "template_id": { "type": "string" },
    "template_ids": { "type": "array", "items": { "type": "string" } },
    "template_version": { "type": "string" },
    "template_contract_path": { "type": "string" },
    "template_contract_paths": { "type": "array", "items": { "type": "string" } },
    "composition_id": { "type": "string" },
    "route": {
      "type": "string",
      "enum": ["remotion_generated", "vfx_overlay", "motion_graphic", "template_component", "source_card_recreation"]
    },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "fps": { "type": "number", "minimum": 1 },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "aspect_ratio": { "type": "string" },
    "alpha": { "type": "boolean" },
    "status": {
      "type": "string",
      "enum": ["planned", "implemented", "previewed", "rendered", "blocked", "approved", "rejected"]
    },
    "component_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "asset_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_asset_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_asset_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "props_schema_path": { "type": "string" },
    "props_path": { "type": "string" },
    "props_sync": {
      "type": "object",
      "required": ["status", "scenario_id", "scene_id", "scene_visual_pack_id", "scene_pack_id", "scenario_scene_fingerprint"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["synced", "stale", "partial", "blocked", "unknown"]
        },
        "scenario_id": { "type": "string" },
        "scenario_path": { "type": "string" },
        "scenario_hash": { "type": "string" },
        "scene_id": { "type": "string" },
        "scene_index": { "type": "integer" },
        "scene_visual_pack_id": { "type": "string" },
        "scene_visual_pack_path": { "type": "string" },
        "scene_pack_id": { "type": "string" },
        "scenario_scene_fingerprint": { "type": "string" },
        "scene_pack_fingerprint": { "type": "string" },
        "props_path": { "type": "string" },
        "props_hash": { "type": "string" },
        "prop_requirement_keys": { "type": "array", "items": { "type": "string" } },
        "missing_prop_keys": { "type": "array", "items": { "type": "string" } },
        "stale_prop_keys": { "type": "array", "items": { "type": "string" } },
        "validated_at": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "template_instance": {
      "type": "object",
      "properties": {
        "template_id": { "type": "string" },
        "template_contract_path": { "type": "string" },
        "props_path": { "type": "string" },
        "override_notes": { "type": "string" },
        "reusable_candidate": { "type": "boolean" }
      }
    },
    "template_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["template_id", "template_contract_path"],
        "properties": {
          "template_id": { "type": "string" },
          "template_contract_path": { "type": "string" },
          "layer_name": { "type": "string" },
          "layer_order": { "type": "integer" },
          "props_path": { "type": "string" },
          "props_inline_summary": { "type": "string" },
          "override_notes": { "type": "string" },
          "reusable_candidate": { "type": "boolean" }
        }
      }
    },
    "bespoke_vfx_notes": { "type": "string" },
    "vfx_rule_refs": { "type": "array", "items": { "type": "string" } },
    "vfx_profile": {
      "type": "object",
      "properties": {
        "complexity": {
          "type": "string",
          "enum": ["simple_css_svg", "dom_heavy", "canvas", "webgl", "three", "skia", "media_heavy", "hybrid", "unknown"]
        },
        "quality_risks": { "type": "array", "items": { "type": "string" } },
        "performance_risks": { "type": "array", "items": { "type": "string" } },
        "determinism_checks": { "type": "array", "items": { "type": "string" } },
        "layout_debug_checks": { "type": "array", "items": { "type": "string" } },
        "agent_preview_analysis": {
          "type": "object",
          "properties": {
            "artifacts_analyzed": { "type": "array", "items": { "type": "string" } },
            "visual_observations": { "type": "array", "items": { "type": "string" } },
            "motion_observations": { "type": "array", "items": { "type": "string" } },
            "pass_decision": { "type": "string", "enum": ["pass", "fail", "partial", "unknown"] }
          }
        },
        "vfx_rule_refs": { "type": "array", "items": { "type": "string" } },
        "render_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["purpose", "command"],
            "properties": {
              "purpose": { "type": "string" },
              "command": { "type": "string" },
              "completed": { "type": "boolean" },
              "notes": { "type": "string" }
            }
          }
        },
        "optimization_notes": { "type": "array", "items": { "type": "string" } },
        "animation_repair_or_replacement": { "type": "string" },
        "fallback_plan": { "type": "string" },
        "benchmark_commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["purpose", "command"],
            "properties": {
              "purpose": { "type": "string" },
              "command": { "type": "string" },
              "completed": { "type": "boolean" },
              "notes": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["pass", "fail", "partial", "not_run"] }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "template_source": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "license_summary": { "type": "string" },
        "approval_required": { "type": "boolean" }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "path"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["component", "rendered_clip", "preview_video", "transparent_video", "still", "debug_screenshot", "image_sequence", "metadata", "preview_analysis", "dom_css_analysis", "debug_report", "qa_report"]
          },
          "path": { "type": "string" },
          "media_asset_id": { "type": "string" },
          "static_file_path": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "preview_frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["frame", "path"],
        "properties": {
          "frame": { "type": "integer", "minimum": 0 },
          "path": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "render_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["purpose", "command"],
        "properties": {
          "purpose": { "type": "string" },
          "command": { "type": "string" },
          "completed": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": { "type": "string" },
          "source_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "qa": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "partial", "not_run"] },
        "summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "description"],
            "properties": {
              "severity": { "type": "string", "enum": ["blocker", "major", "minor", "note"] },
              "frame": { "type": "integer" },
              "timestamp_seconds": { "type": "number" },
              "category": { "type": "string" },
              "description": { "type": "string" },
              "evidence_path": { "type": "string" },
              "recommendation": { "type": "string" },
              "fix_status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
