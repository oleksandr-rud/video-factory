{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RemotionClipPackage",
  "type": "object",
  "required": ["clip_id", "scene_id", "composition_id", "status", "duration_seconds", "fps", "width", "height", "component_paths", "render_commands", "qa"],
  "properties": {
    "clip_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "project_id": { "type": "string" },
    "project_path": { "type": "string" },
    "channel_profile_id": { "type": "string" },
    "channel_slug": { "type": "string" },
    "channel_profile_path": { "type": "string" },
    "media_asset_manifest_path": { "type": "string" },
    "remotion_project_contract_path": { "type": "string" },
    "remotion_app_root_path": { "type": "string" },
    "candidate_id": { "type": "string" },
    "composition_id": { "type": "string" },
    "route": {
      "type": "string",
      "enum": ["remotion_generated", "vfx_overlay", "motion_graphic", "template_component"]
    },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "fps": { "type": "number", "minimum": 1 },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "aspect_ratio": { "type": "string" },
    "alpha": { "type": "boolean" },
    "status": {
      "type": "string",
      "enum": ["planned", "implemented", "previewed", "rendered", "blocked", "approved", "rejected"]
    },
    "component_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "asset_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_asset_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_asset_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "props_schema_path": { "type": "string" },
    "props_path": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "template_source": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "license_summary": { "type": "string" },
        "approval_required": { "type": "boolean" }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "path"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["component", "rendered_clip", "preview_video", "transparent_video", "still", "image_sequence", "metadata", "qa_report"]
          },
          "path": { "type": "string" },
          "media_asset_id": { "type": "string" },
          "static_file_path": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "preview_frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["frame", "path"],
        "properties": {
          "frame": { "type": "integer", "minimum": 0 },
          "path": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "render_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["purpose", "command"],
        "properties": {
          "purpose": { "type": "string" },
          "command": { "type": "string" },
          "completed": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": { "type": "string" },
          "source_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "qa": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "partial", "not_run"] },
        "summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "description"],
            "properties": {
              "severity": { "type": "string", "enum": ["blocker", "major", "minor", "note"] },
              "timestamp_seconds": { "type": "number" },
              "description": { "type": "string" },
              "fix_status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
