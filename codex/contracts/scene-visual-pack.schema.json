{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneVisualPack",
  "type": "object",
  "required": ["scene_visual_pack_id", "scenario_id", "source_scenario_path", "scene_packs"],
  "properties": {
    "scenario_id": { "type": "string" },
    "scene_visual_pack_id": { "type": "string" },
    "source_scenario_path": { "type": "string" },
    "source_scenario_hash": { "type": "string" },
    "source_scenario_version": { "type": "string" },
    "sync_status": {
      "type": "string",
      "enum": ["synced", "partial", "stale", "blocked", "unknown"]
    },
    "sync_report_path": { "type": "string" },
    "project_id": { "type": "string" },
    "project_path": { "type": "string" },
    "channel_profile_id": { "type": "string" },
    "channel_slug": { "type": "string" },
    "channel_profile_path": { "type": "string" },
    "reference_analysis_id": { "type": "string" },
    "channel_format_id": { "type": "string" },
    "channel_format_path": { "type": "string" },
    "media_asset_manifest_path": { "type": "string" },
    "overall_reference_summary": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "reference_analysis_id": { "type": "string" },
        "source_ids": { "type": "array", "items": { "type": "string" } },
        "reference_video_ids": { "type": "array", "items": { "type": "string" } },
        "content_alignment": { "type": "string", "enum": ["match", "partial", "mismatch", "unknown"] },
        "allowed_content_use": {
          "type": "string",
          "enum": ["content_and_visual", "visual_format_only", "content_only", "do_not_use", "unknown"]
        },
        "reference_beat_count": { "type": "integer" },
        "scene_decomposition_count": { "type": "integer" },
        "reusable_patterns": { "type": "array", "items": { "type": "string" } },
        "do_not_copy_risks": { "type": "array", "items": { "type": "string" } },
        "evidence_gaps": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] }
      }
    },
    "visual_research_status": {
      "type": "string",
      "enum": ["not_required", "required_missing", "planned", "complete", "needs_approval", "blocked"]
    },
    "format_requirement_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement_id", "scope", "requirement"],
        "properties": {
          "requirement_id": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": ["channel_format", "producer_criteria", "scene", "template", "vfx", "media", "provider", "other"]
          },
          "scene_ids": { "type": "array", "items": { "type": "string" } },
          "requirement": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "object" } },
          "affected_contracts": { "type": "array", "items": { "type": "string" } },
          "priority": {
            "type": "string",
            "enum": ["required", "recommended", "optional"]
          },
          "approval_needed": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "scene_packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_pack_id", "scene_id", "scene_index", "scenario_scene_fingerprint", "visual_goal", "routes", "candidate_requirements", "prop_requirements"],
        "properties": {
          "scene_pack_id": { "type": "string" },
          "scene_id": { "type": "string" },
          "scene_index": { "type": "integer", "minimum": 0 },
          "start_seconds": { "type": "number" },
          "end_seconds": { "type": "number" },
          "duration_seconds": { "type": "number" },
          "scenario_scene_fingerprint": { "type": "string" },
          "script_fingerprint": { "type": "string" },
          "onscreen_text_fingerprint": { "type": "string" },
          "visual_intent_fingerprint": { "type": "string" },
          "scenario_scene_lineage": {
            "type": "object",
            "properties": {
              "scenario_id": { "type": "string" },
              "scenario_path": { "type": "string" },
              "scenario_hash": { "type": "string" },
              "scene_id": { "type": "string" },
              "scene_index": { "type": "integer" },
              "scene_fingerprint": { "type": "string" },
              "validated_at": { "type": "string" }
            }
          },
          "visual_goal": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } },
          "source_asset_ids": { "type": "array", "items": { "type": "string" } },
          "reference_beat_ids": { "type": "array", "items": { "type": "string" } },
          "reference_use_policy": {
            "type": "string",
            "enum": ["content_and_visual", "visual_format_only", "content_only", "do_not_use", "not_applicable"]
          },
          "target_content_substitution": { "type": "string" },
          "reference_materials": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "material_id": { "type": "string" },
                "kind": { "type": "string" },
                "source_id": { "type": "string" },
                "asset_id": { "type": "string" },
                "reference_beat_id": { "type": "string" },
                "path_or_url": { "type": "string" },
                "start_seconds": { "type": "number" },
                "end_seconds": { "type": "number" },
                "usage": { "type": "string" },
                "rights_state": { "type": "string" },
                "evidence_refs": { "type": "array", "items": { "type": "object" } },
                "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] }
              }
            }
          },
          "scene_decomposition": {
            "type": "object",
            "properties": {
              "decomposition_refs": { "type": "array", "items": { "type": "string" } },
              "reference_scene_summary": { "type": "string" },
              "visual_patterns": { "type": "array", "items": { "type": "string" } },
              "audio_or_pacing_patterns": { "type": "array", "items": { "type": "string" } },
              "caption_or_graphics_patterns": { "type": "array", "items": { "type": "string" } },
              "do_not_copy_risks": { "type": "array", "items": { "type": "string" } },
              "evidence_refs": { "type": "array", "items": { "type": "object" } },
              "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] }
            }
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "evidence_id": { "type": "string" },
                "source_id": { "type": "string" },
                "asset_id": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          },
          "mood": { "type": "string" },
          "camera_or_motion": { "type": "string" },
          "format_rules_applied": { "type": "array", "items": { "type": "string" } },
          "anti_redundancy_notes": { "type": "string" },
          "routes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "remotion_generated",
                "ai_video_generation",
                "stock_clip",
                "user_supplied_media",
                "approved_web_image",
                "source_card_recreation"
              ]
            }
          },
          "candidate_requirements": {
            "type": "object",
            "properties": {
              "min_resolution": { "type": "string" },
              "aspect_ratio": { "type": "string" },
              "min_duration_seconds": { "type": "number" },
              "needs_people": { "type": "boolean" },
              "needs_product_or_ui": { "type": "boolean" },
              "brand_safety_notes": { "type": "string" }
            }
          },
          "prop_requirements": {
            "type": "object",
            "properties": {
              "scenario_id": { "type": "string" },
              "scenario_path": { "type": "string" },
              "scene_visual_pack_id": { "type": "string" },
              "scene_pack_id": { "type": "string" },
              "scene_id": { "type": "string" },
              "scene_index": { "type": "integer" },
              "scenario_scene_fingerprint": { "type": "string" },
              "start_seconds": { "type": "number" },
              "end_seconds": { "type": "number" },
              "duration_seconds": { "type": "number" },
              "narration_text": { "type": "string" },
              "onscreen_text": { "type": "string" },
              "visual_intent": { "type": "string" },
              "source_ids": { "type": "array", "items": { "type": "string" } },
              "claim_ids": { "type": "array", "items": { "type": "string" } },
              "evidence_refs": { "type": "array", "items": { "type": "object" } },
              "media_asset_ids": { "type": "array", "items": { "type": "string" } },
              "static_file_paths": { "type": "array", "items": { "type": "string" } },
              "safe_area_rules": { "type": "array", "items": { "type": "string" } },
              "template_ids": { "type": "array", "items": { "type": "string" } },
              "route": { "type": "string" },
              "style_refs": { "type": "array", "items": { "type": "string" } },
              "route_specific_props": { "type": "object" }
            }
          },
          "sync_status": {
            "type": "string",
            "enum": ["synced", "missing_downstream", "stale_downstream", "orphaned_downstream", "conflicting_routes", "needs_director_decision", "unknown"]
          },
          "search_queries": { "type": "array", "items": { "type": "string" } },
          "ai_generation_prompts": { "type": "array", "items": { "type": "string" } },
          "ai_video_generation_brief": { "type": "string" },
          "invideo_model_hint": { "type": "string" },
          "reference_asset_paths": { "type": "array", "items": { "type": "string" } },
          "negative_constraints": { "type": "array", "items": { "type": "string" } },
          "remotion_scene_brief": { "type": "string" },
          "remotion_clip_brief": { "type": "string" },
          "animation_style": { "type": "string" },
          "template_hint": { "type": "string" },
          "template_id": { "type": "string" },
          "template_ids": { "type": "array", "items": { "type": "string" } },
          "template_contract_path": { "type": "string" },
          "template_contract_paths": { "type": "array", "items": { "type": "string" } },
          "reusable_template_requirements": {
            "type": "object",
            "properties": {
              "preferred_categories": { "type": "array", "items": { "type": "string" } },
              "required_safe_areas": { "type": "array", "items": { "type": "string" } },
              "alpha_required": { "type": "boolean" },
              "must_reuse_existing": { "type": "boolean" },
              "allow_bespoke_vfx": { "type": "boolean" },
              "allow_multiple_templates": { "type": "boolean" },
              "notes": { "type": "string" }
            }
          },
          "vfx_requirements": { "type": "array", "items": { "type": "string" } },
          "vfx_rule_refs": { "type": "array", "items": { "type": "string" } },
          "handoff_recommendations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["recommendation_id", "to_agent", "handoff_type", "route", "reason", "required_inputs", "output_contract", "definition_of_done"],
              "properties": {
                "recommendation_id": { "type": "string" },
                "to_agent": {
                  "type": "string",
                  "enum": ["invideo-ai-generator", "remotion-clip-builder"]
                },
                "handoff_type": {
                  "type": "string",
                  "enum": ["feasibility_check", "production_request", "candidate_generation", "revision_request"]
                },
                "route": {
                  "type": "string",
                  "enum": ["remotion_generated", "ai_video_generation", "source_card_recreation"]
                },
                "priority": {
                  "type": "string",
                  "enum": ["primary", "fallback", "optional"]
                },
                "reason": { "type": "string" },
                "required_inputs": { "type": "array", "items": { "type": "string" } },
                "output_contract": { "type": "string" },
                "definition_of_done": { "type": "array", "items": { "type": "string" } },
                "approval_notes": { "type": "string" },
                "blocked_until": { "type": "string" }
              }
            }
          },
          "format_requirement_updates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["requirement_id", "scope", "requirement"],
              "properties": {
                "requirement_id": { "type": "string" },
                "scope": {
                  "type": "string",
                  "enum": ["channel_format", "producer_criteria", "scene", "template", "vfx", "media", "provider", "other"]
                },
                "scene_ids": { "type": "array", "items": { "type": "string" } },
                "requirement": { "type": "string" },
                "evidence_refs": { "type": "array", "items": { "type": "object" } },
                "affected_contracts": { "type": "array", "items": { "type": "string" } },
                "priority": {
                  "type": "string",
                  "enum": ["required", "recommended", "optional"]
                },
                "approval_needed": { "type": "boolean" },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
