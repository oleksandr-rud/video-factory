{
  "$schema": "../../codex/contracts/remotion-template.schema.json",
  "template_id": "vf.source-card.standard.v1",
  "name": "Standard Source Card",
  "version": "1.0.0",
  "status": "previewed",
  "category": "source_card",
  "owner_agent": "remotion-clip-builder",
  "remotion_project_contract_path": "remotion/remotion-project.json",
  "remotion_app_root_path": "remotion",
  "template_registry_path": "remotion/src/templateRegistry.tsx",
  "composition_id": "TemplateSourceCardStandard",
  "composition_type": "template",
  "component_paths": [
    "remotion/src/templates/source-cards/SourceCard.tsx"
  ],
  "registry_paths": [
    "remotion/src/templateRegistry.tsx"
  ],
  "props_contract": {
    "required": ["sourceName"],
    "optional": ["eyebrow", "sourceDetail", "claim", "accentColor", "backgroundColor", "textColor"],
    "notes": "Use for source-backed statements. Keep exact citations in props and evidence refs, not component internals."
  },
  "supported_aspect_ratios": ["9:16", "16:9", "1:1"],
  "supported_dimensions": [
    { "width": 1080, "height": 1920 },
    { "width": 1920, "height": 1080 }
  ],
  "duration": {
    "default_seconds": 6,
    "min_seconds": 4,
    "max_seconds": 14,
    "fps": 30
  },
  "alpha": {
    "supports_transparency": false,
    "preferred_export": "rendered_clip",
    "notes": "Template includes a full-frame background."
  },
  "safe_areas": {
    "caption_safe": false,
    "cta_safe": true,
    "reserved_zones": ["center card"],
    "notes": "Do not layer burned-in captions over the card unless the caption area is explicitly moved."
  },
  "usage": {
    "when_to_use": ["Evidence cards", "Article citations", "Reference video callouts", "Claim receipts"],
    "when_not_to_use": ["Tiny lower-third source labels", "Motion-only transitions", "Dense legal citations"],
    "instance_output_contract": "codex/contracts/remotion-clip-package.schema.json",
    "handoff_notes": ["Pair with evidence_refs and source asset ids in the scene clip package."]
  },
  "dependencies": [
    {
      "name": "remotion",
      "version": "4.0.462",
      "purpose": "Frame-aware animation primitives",
      "license_summary": "Remotion package license applies",
      "approval_required": false
    }
  ],
  "source": {
    "created_from": "core_remotion",
    "license_summary": "Repo-local component",
    "approval_required": false
  },
  "render_commands": [
    {
      "purpose": "preview still",
      "command": "npx remotion still TemplateSourceCardStandard out/template-source-card.png --frame=30 --scale=0.25",
      "completed": true,
      "notes": "Rendered preview still for template validation."
    }
  ],
  "preview_frames": [
    {
      "frame": 30,
      "path": "remotion/out/template-source-card.png",
      "notes": "Preview still rendered at 0.25 scale."
    }
  ],
  "qa": {
    "status": "pass",
    "summary": "Template preview still rendered successfully.",
    "checks": ["npx remotion still TemplateSourceCardStandard out/template-source-card.png --frame=30 --scale=0.25"]
  }
}
