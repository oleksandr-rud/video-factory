    "approval_required": false
  },
  "render_commands": [
    {
      "purpose": "preview still",
      "command": "npx remotion still TemplateLowerThirdMinimal out/template-lower-third.png --frame=30 --scale=0.25",
      "completed": true,
      "notes": "Rendered preview still for template validation."
    }
  ],
  "preview_frames": [
