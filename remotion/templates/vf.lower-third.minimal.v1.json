  "props_contract": {
    "required": ["title"],
    "optional": ["label", "detail", "align", "accentColor", "backgroundColor", "textColor", "safeBottom"],
    "notes": "Use scene-specific props for all copy and colors. Do not hardcode names or claims into the component."
  },
  "supported_aspect_ratios": ["9:16", "16:9", "1:1"],
  "supported_dimensions": [
    { "width": 1080, "height": 1920 },
    { "width": 1920, "height": 1080 }
