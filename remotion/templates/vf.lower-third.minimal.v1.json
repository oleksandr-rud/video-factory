  "duration": {
    "default_seconds": 5,
    "min_seconds": 3,
    "max_seconds": 12,
    "fps": 30
  },
  "alpha": {
    "supports_transparency": true,
    "preferred_export": "transparent_overlay",
    "notes": "Component itself has no full-frame opaque background."
  },
  "safe_areas": {
    "caption_safe": true,
    "cta_safe": true,
    "reserved_zones": ["lower-left or lower-right depending on align"],
    "notes": "Avoid using simultaneous bottom captions unless captions are moved above the lower third."
  },
  "usage": {
    "when_to_use": ["Source labels", "Speaker IDs", "Chapter labels", "Short context tags"],
    "when_not_to_use": ["Long paragraphs", "Full citation cards", "Primary title cards"],
    "instance_output_contract": "codex/contracts/remotion-clip-package.schema.json",
    "handoff_notes": ["Create a scene-specific clip package with title/detail props and template provenance."]
  },
  "dependencies": [
    {
      "name": "remotion",
      "version": "4.0.462",
      "purpose": "Frame-aware animation primitives",
