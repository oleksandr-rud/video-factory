# Video Factory environment example.
# Copy values into your local shell or a private .env file. Do not commit real secrets.

# Required only when executing OpenRouter API calls.
OPENROUTER_API_KEY=

# Optional OpenRouter defaults.
OPENROUTER_VIDEO_MODEL=qwen/qwen3.6-plus
OPENROUTER_VIDEO_REVIEW_MAX_FRAME_IMAGES=12

# Required only when executing OpenAI sampled-frame critique.
OPENAI_API_KEY=

# Optional OpenAI vision model default.
OPENAI_VISION_MODEL=gpt-5.2

# Required only when listing ElevenLabs voices or generating ElevenLabs TTS.
ELEVENLABS_API_KEY=

# Required only when executing Freepik/Magnific stock video search or downloads.
FREEPIK_API_KEY=

# Optional compatibility key name for the current Magnific-branded API docs.
MAGNIFIC_API_KEY=

# Optional Freepik/Magnific stock video defaults.
FREEPIK_API_BASE_URL=https://api.magnific.com
FREEPIK_VIDEO_SEARCH_LANGUAGE=en-US
FREEPIK_VIDEO_SEARCH_LIMIT=25

# Optional local reference-analysis defaults.
REFERENCE_ANALYSIS_MAX_SCENES=24
REFERENCE_ANALYSIS_MAX_FRAMES=72
REFERENCE_ANALYSIS_FRAMES_PER_SCENE=3
REFERENCE_ANALYSIS_FALLBACK_SEGMENT_SECONDS=8
REFERENCE_ANALYSIS_ENABLE_OCR=false
REFERENCE_ANALYSIS_ENABLE_WHISPERX=false
REFERENCE_ANALYSIS_ENABLE_CLIP=false
REFERENCE_ANALYSIS_ENABLE_DIRECT_VIDEO_MODEL=false
